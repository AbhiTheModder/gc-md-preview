{
  "name": "gc-md-preview",
  "version": "0.1.0",
  "description": "Preview .md attachments inline in Google Chat.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "test": "vitest run",
    "firefox": "web-ext run --source-dir dist/firefox",
    "chrome": "echo 'Load dist/chrome via chrome://extensions (unpacked)'",
    "package": "node scripts/package.mjs",
    "package:chrome": "node scripts/package.mjs chrome",
    "package:firefox": "node scripts/package.mjs firefox",
    "clean": "rm -rf dist dist-zip"
  },
  "license": "MIT",
  "author": "AbhiTheModder",
  "dependencies": {
    "dompurify": "^3.2.0",
    "highlight.js": "^11.10.0",
    "marked": "^14.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.23.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "sharp": "^0.35.2",
    "vitest": "^2.1.0",
    "web-ext": "^8.3.0"
  },
  "aube": {
    "allowBuilds": {
      "esbuild": true,
      "spawn-sync": true
    }
  }
}
